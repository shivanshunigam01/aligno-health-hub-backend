NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/aligno_health_hub
JWT_ACCESS_SECRET=replace_with_64_char_secret_minimum_length_here
JWT_REFRESH_SECRET=replace_with_64_char_refresh_secret_minimum
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
# CORS — all origins allowed (configured in app.js)
CORS_ORIGINS=*
CLIENT_URL=http://localhost:5173
BCRYPT_ROUNDS=12
LOG_LEVEL=info

# Cloudinary — replace with your credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=aligno

# Razorpay — replace with your credentials
RAZORPAY_KEY_ID=rzp_test_key
RAZORPAY_KEY_SECRET=rzp_secret
RAZORPAY_WEBHOOK_SECRET=webhook_secret

# Email (optional — OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Aligno Health Hub <no-reply@aligno.local>

# Business rules (matches frontend)
SHIPPING_FREE_ABOVE=999
SHIPPING_DEFAULT_CHARGE=79
GST_PERCENT=5

# Seed admin account
SUPER_ADMIN_EMAIL=admin@alignohealthhub.com
SUPER_ADMIN_PASSWORD=Admin@12345
